<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/style.css" />
    <title><%= locals.pageTitle %> | <%= locals.appTitle %></title>
  </head>
  <body>
    <%- include("partials/header") %>

    <main>
      <h2>my drive</h2>

      <div class="row gap-s">
        <b>Current Path:</b>
        <span class="row">
          <a href="/drive/root">root</a> <%
          locals.parentFolders.forEach((parentFolder) => { %> /<a
            href="/drive/<%= parentFolder.id %>"
            ><%= parentFolder.name %></a
          >
          <% }) %>
        </span>
      </div>

      <%- include("partials/forms/create-folder") %>

      <div>
        <ul>
          <% if (locals.childFolders) { %>

          <% locals.childFolders.forEach((childFolder) => { %>
          <li>
            <a href="/drive/<%= childFolder.id %>"> <%= childFolder.name %> </a>
          </li>

          <% }) %>
          <% } %>
        </ul>
      </div>
    </main>
  </body>
</html>
