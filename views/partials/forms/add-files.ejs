<form action="/drive/<%= locals.folderId %>/folder/create" method="post">
  <h2>Create folder</h2>
  <%- include("../errors") %>
  <label for="folderName"
    >Folder name: <input type="text" name="folderName" id="folderName" required
  /></label>
  <button type="submit">Create</button>
</form>

<form
  action="/drive/<%= locals.folderId %>/file/create"
  method="post"
  enctype="multipart/form-data"
>
  <h2>Add File</h2>
  <input type="file" name="uploadFiles" multiple required />
  <button type="submit">Add file</button>
</form>
